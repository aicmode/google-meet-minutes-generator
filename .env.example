# このファイルを .env にコピーして、実際の値を設定してください
#   cp .env.example .env

# ----- OpenAI -----
# OpenAI の APIキー(必須) https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# 文字起こしに使う Whisper のモデル(省略可、デフォルト: whisper-1)
WHISPER_MODEL=whisper-1

# 議事録生成に使うモデル(省略可、デフォルト: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ----- Google API -----
# OAuth クライアントの認証情報ファイル(省略可、デフォルト: credentials.json)
GOOGLE_CREDENTIALS_FILE=credentials.json

# 認証トークンの保存先(省略可、デフォルト: token.json)
GOOGLE_TOKEN_FILE=token.json

# 議事録を保存する Google Drive のフォルダID(省略可)
# フォルダのURL https://drive.google.com/drive/folders/XXXX の XXXX 部分
GOOGLE_DRIVE_FOLDER_ID=

# ----- その他 -----
# 録音ファイルを置くフォルダ(省略可、デフォルト: recordings)
RECORDINGS_DIR=recordings
